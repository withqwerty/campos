{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@withqwerty/campos-schema": ["packages/schema/src/index.ts"],
      "@withqwerty/campos-adapters": ["packages/adapters/src/index.ts"],
      "@withqwerty/campos-react": ["packages/react/src/index.ts"],
      "@withqwerty/campos-static": ["packages/static/src/index.tsx"],
      "@withqwerty/campos-stadia": ["packages/stadia/src/index.ts"]
    }
  }
}
