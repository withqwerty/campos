{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Game",
  "description": "Game metadata. Only id is required.",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "date": { "type": ["string", "null"], "format": "date" },
    "homeTeamId": { "type": ["string", "null"] },
    "awayTeamId": { "type": ["string", "null"] },
    "homeScore": { "type": ["integer", "null"] },
    "awayScore": { "type": ["integer", "null"] },
    "seasonId": { "type": ["string", "null"] },
    "competitionId": { "type": ["string", "null"] }
  },
  "required": ["id"]
}
